{% import '_includes/forms.twig' as forms %}
{% from 'co-pilot/settings/_macros' import configWarning %}

<div class="flex items-start" style="gap: 24px;">
    <div style="flex: 2;">
        {{ forms.autosuggestField({
            label: 'Langdock API Key',
            instructions: 'The environment variable containing your Langdock API key.',
            id: 'providerSettings-_langdock-apiKeyEnvVar',
            name: 'providerSettings[_langdock][apiKeyEnvVar]',
            value: config.apiKeyEnvVar ?? '',
            suggestEnvVars: true,
            placeholder: '$LANGDOCK_API_KEY',
            disabled: fileConfig.apiKeyEnvVar is defined,
            warning: fileConfig.apiKeyEnvVar is defined ? configWarning('providerSettings._langdock.apiKeyEnvVar'),
            errors: [],
        }) }}
    </div>
    <div style="flex: 1;">
        {{ forms.selectField({
            label: 'Region',
            instructions: 'Data residency region for API requests.',
            id: 'providerSettings-_langdock-region',
            name: 'providerSettings[_langdock][region]',
            value: config.region ?? 'eu',
            options: [
                { label: 'EU', value: 'eu' },
                { label: 'US', value: 'us' },
            ],
            disabled: fileConfig.region is defined,
            warning: fileConfig.region is defined ? configWarning('providerSettings._langdock.region'),
            errors: [],
        }) }}
    </div>
</div>

<hr>

<div class="flex items-start" style="gap: 12px; margin-bottom: 12px;">
    <h2 class="mb-6">Available Models</h2>
    {% if hasApiKey %}
        <button type="button" class="btn small" id="refresh-models-btn" title="Refresh model cache" onclick="(function(btn){
            var spinner = btn.nextElementSibling;
            btn.classList.add('disabled');
            spinner.classList.remove('hidden');
            Craft.sendActionRequest('POST', 'co-pilot-langdock/cache/invalidate-models')
                .then(function() {
                    Craft.cp.displayNotice('Model cache cleared.');
                    location.reload();
                })
                .catch(function() {
                    Craft.cp.displayError('Failed to clear model cache.');
                    btn.classList.remove('disabled');
                    spinner.classList.add('hidden');
                });
        })(this)">
            Refresh Models
        </button>
        <div class="spinner hidden"></div>
    {% endif %}
</div>

<div class="flex" style="gap: 24px;">
    {% for item in providerModels %}
        <div style="flex: 1;">
            {% if item.models|length %}
                {{ forms.selectField({
                    label: item.label ~ ' Model',
                    instructions: 'Default model for new chats.',
                    id: 'providerSettings-' ~ item.handle ~ '-model',
                    name: 'providerSettings[' ~ item.handle ~ '][model]',
                    value: item.config.model ?? '',
                    options: item.models|map(m => { label: m, value: m }),
                    errors: [],
                }) }}
            {% else %}
                <div class="field">
                    <div class="heading"><label>{{ item.label }} Model</label></div>
                    <div class="instructions"><p>Default model for new chats.</p></div>
                    {% if not (config.apiKeyEnvVar ?? '') %}
                        <p class="light">Enter your API key above and save to load available models.</p>
                    {% else %}
                        <p class="light">No models available. Enable them in Langdock.</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    {% endfor %}
</div>
